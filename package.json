{
  "name": "pcset",
  "version": "0.2.0",
  "description": "Post-tonal pitch-class set theory: normal order, prime form, interval-class vector, Z-relations, and set-class analysis. Typed, zero dependencies, browser and Node.",
  "keywords": [
    "music",
    "music-theory",
    "pitch-class",
    "set-theory",
    "atonal",
    "post-tonal",
    "forte",
    "interval-vector",
    "prime-form",
    "normal-order",
    "z-relation",
    "computational-musicology"
  ],
  "license": "MIT",
  "author": "Amaar Chughtai",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/analyze.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amaar-mc/pcset.git"
  },
  "homepage": "https://github.com/amaar-mc/pcset#readme",
  "bugs": {
    "url": "https://github.com/amaar-mc/pcset/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "fast-check": "^4.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
